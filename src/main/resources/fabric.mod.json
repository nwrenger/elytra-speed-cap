{
  "schemaVersion": 1,
  "id": "elytra-speed-cap",
  "version": "${version}",
  "name": "Elytra Speed Cap",
  "description": "Limit the maximum speed of elytra flight to a configurable value.",
  "authors": ["nwrenger"],
  "contact": {
    "homepage": "https://modrinth.com/mod/elytra-speed-cap",
    "sources": "https://github.com/nwrenger/elytra-speed-cap",
    "issues": "https://github.com/nwrenger/elytra-speed-cap/issues"
  },
  "license": "MIT",
  "icon": "assets/elytra-speed-cap/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["io.github.nwrenger.elytraspeedcap.ElytraSpeedCap"],
    "client": ["io.github.nwrenger.elytraspeedcap.ElytraSpeedCapClient"]
  },
  "mixins": [
    "elytra-speed-cap.mixins.json",
    {
      "config": "elytra-speed-cap.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": "*",
    "minecraft": "1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  }
}
